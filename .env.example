# Ambiente
NODE_ENV=development
PORT=3001

# Autenticação
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$...
SESSION_SECRET=sua_chave_secreta_aqui_min_32_caracteres

# Telegram (opcional - pode configurar pelo painel)
# API_ID=37177269
# API_HASH=sua_api_hash_aqui

# Discord Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/seu-webhook-aqui

# Monitor
CHECK_INTERVAL_SECONDS=30
MIN_TIME_BETWEEN_MESSAGES=30
URGENT_ENABLED=true

# Banco
DATABASE_PATH=./data/promo-monitor.db
